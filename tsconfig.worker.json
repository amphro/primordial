{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "composite": true,
    "outDir": "./.tsbuild/worker"
  },
  "include": ["worker/**/*", "worker-configuration.d.ts"]
}
