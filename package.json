{
  "name": "primordial",
  "version": "1.0.0",
  "description": "A cellular automaton game where natural language strategies are your only weapon",
  "author": "Thomas Dvornik",
  "scripts": {
    "dev:worker": "wrangler dev --port 8787",
    "dev:ui": "vite",
    "build": "vite build",
    "types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply primordial-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply primordial-db --remote",
    "deploy": "npm run build && wrangler deploy",
    "export:games": "node scripts/export-games.mjs"
  },
  "keywords": ["game", "cloudflare", "workers", "ai"],
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  }
}
